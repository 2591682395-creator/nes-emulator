# Supabase 配置
# 从 Supabase 控制台获取: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Qiniu public/custom domain, without a trailing slash.
# The ROM objects are expected under the game/ directory.
QINIU_BASE_URL=https://games.example.com
